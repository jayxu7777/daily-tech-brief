# Telegram bot credentials
# 1. Create a bot via @BotFather on Telegram, send /newbot, follow prompts
# 2. Copy the HTTP API token below
TELEGRAM_BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3. Send any message to your bot from your Telegram account first
# 4. Visit https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates and copy chat.id
TELEGRAM_CHAT_ID=123456789
